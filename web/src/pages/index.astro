---
import Base from "../layouts/Base.astro";
---
<Base title="CredVerify — Decentralized Credential Verification">
  <header class="border-b border-slate-800 px-6 py-4">
    <div class="max-w-4xl mx-auto flex justify-between items-center">
      <h1 class="text-2xl font-bold">🎓 CredVerify</h1>
      <span class="text-slate-500 text-sm">Trustless hiring powered by GenLayer</span>
    </div>
  </header>

  <main class="max-w-4xl mx-auto p-6 grid md:grid-cols-2 gap-6 mt-6">
    <!-- Left: Create Role -->
    <section class="bg-slate-900 rounded-xl p-6 border border-slate-800">
      <h2 class="text-lg font-semibold mb-4 text-indigo-400">Define a Role</h2>
      <form class="space-y-3">
        <input
          type="text"
          placeholder="Role title (e.g. Senior Rust Developer)"
          class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-indigo-500 focus:outline-none"
        />
        <textarea
          placeholder="Requirements — what skills/experience are needed?"
          rows="4"
          class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 resize-none focus:border-indigo-500 focus:outline-none"
        ></textarea>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-xs text-slate-400">GitHub weight (%)</label>
            <input type="number" value="70" min="0" max="100"
              class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white focus:border-indigo-500 focus:outline-none" />
          </div>
          <div>
            <label class="text-xs text-slate-400">Min score to pass</label>
            <input type="number" value="60" min="0" max="100"
              class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white focus:border-indigo-500 focus:outline-none" />
          </div>
        </div>
        <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 rounded-lg px-4 py-2.5 font-semibold transition">
          Create Role
        </button>
      </form>
    </section>

    <!-- Right: Apply -->
    <section class="bg-slate-900 rounded-xl p-6 border border-slate-800">
      <h2 class="text-lg font-semibold mb-4 text-emerald-400">Apply for Verification</h2>
      <form class="space-y-3">
        <input
          type="text"
          placeholder="Role key (e.g. 0)"
          class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-emerald-500 focus:outline-none"
        />
        <input
          type="text"
          placeholder="GitHub username"
          class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-emerald-500 focus:outline-none"
        />
        <input
          type="url"
          placeholder="LinkedIn URL (optional)"
          class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 focus:border-emerald-500 focus:outline-none"
        />
        <textarea
          placeholder="Extra notes — anything validators should know"
          rows="2"
          class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2.5 text-white placeholder-slate-500 resize-none focus:border-emerald-500 focus:outline-none"
        ></textarea>
        <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 rounded-lg px-4 py-2.5 font-semibold transition">
          Submit for Verification
        </button>
      </form>
    </section>

    <!-- Bottom: How it works -->
    <section class="md:col-span-2 bg-slate-900 rounded-xl p-6 border border-slate-800">
      <h3 class="font-semibold mb-4">How CredVerify works</h3>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 text-sm text-slate-400">
        <div>
          <p class="text-indigo-400 font-medium mb-1">1. Define</p>
          <p>DAO creates a role with requirements and scoring weights.</p>
        </div>
        <div>
          <p class="text-emerald-400 font-medium mb-1">2. Apply</p>
          <p>Candidate provides GitHub username. No resume needed.</p>
        </div>
        <div>
          <p class="text-amber-400 font-medium mb-1">3. Verify</p>
          <p>AI validators fetch profile, score against requirements.</p>
        </div>
        <div>
          <p class="text-rose-400 font-medium mb-1">4. Access</p>
          <p>Qualified? HireGate grants on-chain role access.</p>
        </div>
      </div>
    </section>
  </main>
</Base>
